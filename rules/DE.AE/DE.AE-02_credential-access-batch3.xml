<!-- 
  Batch 3: Credential Access & Privilege Escalation (Rules 100035 - 100041)
  NIST Focus: PR.AA-05, DE.AE-02, DE.CM-03, ID.RA-03
-->

<group name="windows, sysmon, security, nist_csf, mitre_attack, linux, auditd,">

  <!-- Rule 100035: LSASS Memory Access (Credential Dumping) -->
  <rule id="100035" level="12">
    <if_sid>61611</if_sid> <!-- Sysmon Event ID 10 (ProcessAccess) -->
    <regex type="pcre2">(?i)TargetImage.*lsass\.exe.*GrantedAccess.*(0x1010|0x1410|0x143a|0x1f0fff|0x1fffff)</regex>
    <description>LSASS memory access detected (Credential Dumping)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>DE.AE-02, PR.AA-05</group>
  </rule>

  <!-- Rule 100036: Mimikatz Indicators -->
  <rule id="100036" level="14">
    <if_sid>61603, 61611, 60103</if_sid>
    <regex type="pcre2">(?i)(sekurlsa|lsadump|kerberos::|crypto::|privilege::debug|mimikatz)</regex>
    <description>CRITICAL: Mimikatz credential dumping indicators detected</description>
    <mitre>
      <id>T1003</id>
    </mitre>
    <group>DE.AE-02, RS.MA-02</group>
  </rule>

  <!-- Rule 100037: Pass-the-Hash Indicators -->
  <rule id="100037" level="12">
    <if_sid>60106</if_sid> <!-- Security Event 4624 -->
    <regex type="pcre2">(?i)LogonType.*9.*LogonProcessName.*seclogo.*AuthenticationPackageName.*Negotiate</regex>
    <description>Pass-the-Hash (PtH) indicators detected (Lateral Movement)</description>
    <mitre>
      <id>T1550.002</id>
    </mitre>
    <group>DE.AE-02, DE.CM-01</group>
  </rule>

  <!-- Rule 100038: DCSync Attack (Replication Rights Abuse) -->
  <rule id="100038" level="14">
    <if_sid>60106, 60103</if_sid> <!-- Base Security events, highly simplified for XML logic. Real world requires 4662 -->
    <regex type="pcre2">(?i)(1131f6aa-9c07-11d1-f79f-00c04fc2dcd2|1131f6ad-9c07-11d1-f79f-00c04fc2dcd2|89e95b76-ceed-11d0-929a-00c04fd92fcb).*AccessMask.*0x100</regex>
    <description>CRITICAL: DCSync replication rights abuse detected (Credential Dumping)</description>
    <mitre>
      <id>T1003.006</id>
    </mitre>
    <group>DE.AE-02, ID.RA-03</group>
  </rule>

  <!-- Rule 100039: Kerberoasting Indicators -->
  <rule id="100039" level="10">
    <!-- Looking for Security 4769 (TGS Request) using weak RC4 encryption (0x17) -->
    <if_sid>60106, 60103</if_sid>
    <regex type="pcre2">(?i)TicketOptions.*0x40810000.*TicketEncryptionType.*0x17</regex>
    <description>Kerberoasting indicators (RC4 TGS requests) (Credential Access)</description>
    <mitre>
      <id>T1558.003</id>
    </mitre>
    <group>DE.AE-02, ID.RA-03</group>
  </rule>

  <!-- Rule 100040: Multiple Account Lockouts (Coordinated Attack) -->
  <rule id="100040" level="10" frequency="5" timeframe="300">
    <if_matched_sid>60106</if_matched_sid> <!-- Base logic. Actual Event ID for lockout is 4740 -->
    <regex type="pcre2">(?i)EventID.*4740</regex>
    <same_source_ip />
    <description>Multiple account lockouts detected from single source (Brute Force/DoS)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>DE.AE-02, DE.CM-03</group>
  </rule>

  <!-- Rule 100041: Linux Password File Accessed by Non-Root Process -->
  <rule id="100041" level="8">
    <if_sid>80700</if_sid> <!-- Auditd syscall -->
    <regex type="pcre2">(?i)path=\/etc\/(shadow|passwd)\s.*uid=[^0]\b.*exe="(?!(\/usr\/bin\/(sudo|passwd|su|login|sshd)))</regex>
    <description>Linux password/shadow file accessed by non-root, non-standard process</description>
    <mitre>
      <id>T1003.008</id>
    </mitre>
    <group>PR.AA-05, DE.CM-03</group>
  </rule>

</group>
