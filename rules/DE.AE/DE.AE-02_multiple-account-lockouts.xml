<!--
  Rule: Multiple account lockouts detected from single source (Brute Force/DoS)
  NIST CSF: DE.CM-01, PR.AC-04
  MITRE ATT&CK: T1110
  Severity: High
  Author: Subhash Bharadwaj
  Last Updated: 2026-05-23
  Note: Contains silent helper rule for correlation.
-->

<group name="nist_csf, de.ae-02, mitre_attack,">

  <rule id="100055" level="1">
      <decoded_as>json</decoded_as>
      <field name="win.system.providerName">Microsoft-Windows-Security-Auditing</field>
      <field name="win.system.eventID">^4740$</field>
      <options>no_log</options>
      <description>Helper: Single Account Lockout</description>
    </rule>

  <rule id="100040" level="10" frequency="5" timeframe="300">
      <if_matched_sid>100055</if_matched_sid>
      <same_field>win.eventdata.ipAddress</same_field>
      <description>Multiple account lockouts detected from single source (Brute Force/DoS)</description>
      <mitre>
        <id>T1110</id>
      </mitre>
      <group>DE.CM-01, PR.AC-04</group>
    </rule>

</group>
