<!-- 
  Batch 4: C2, Exfiltration & Living-off-the-Land (Rules 100042 - 100048)
  NIST Focus: DE.CM-01, DE.AE-03, DE.AE-02, PR.DS-02
-->

<group name="linux, auditd, windows, sysmon, iptables, proxy, nist_csf, mitre_attack,">

  <!-- Rule 100042: Reverse Shell Spawned -->
  <rule id="100042" level="12">
    <if_sid>80700, 61603</if_sid> <!-- Auditd syscall or Sysmon process creation -->
    <regex type="pcre2">(?i)(bash\s-i|sh\s-i|nc\s-e|\/dev\/tcp\/|mkfifo\s.*?nc)</regex>
    <description>Reverse shell execution detected (Command and Control)</description>
    <mitre>
      <id>T1059.004</id>
    </mitre>
    <group>DE.AE-02, RS.MA-02</group>
  </rule>

  <!-- Rule 100043: Base64 Encoded Command Execution -->
  <rule id="100043" level="9">
    <if_sid>80700, 61603</if_sid>
    <!-- Simple heuristic for common base64 CLI flags + long base64 strings -->
    <regex type="pcre2">(?i)(\-e\s|\-enc\s|base64\s-d).*?[A-Za-z0-9+/]{30,}={0,2}</regex>
    <description>Suspicious Base64 encoded command execution (Obfuscation)</description>
    <mitre>
      <id>T1027</id>
    </mitre>
    <group>DE.AE-02, DE.CM-03</group>
  </rule>

  <!-- Rule 100044: DNS Tunneling Indicators -->
  <rule id="100044" level="10">
    <decoded_as>json</decoded_as>
    <field name="win.system.providerName">Microsoft-Windows-Sysmon</field>
    <field name="win.system.eventID">^22$</field>
    <field name="win.eventdata.queryName" type="pcre2">(?i)[A-Za-z0-9\-\.]{40,}\.(com|net|org|io|xyz)</field>
    <description>Suspiciously long DNS query indicating potential DNS Tunneling (C2)</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
    <group>DE.AE-03, RS.AN-01</group>
  </rule>

  <!-- Rule 100045: TOR Exit Node Connection -->
  <rule id="100045" level="12">
    <!-- Relies on custom iptables or proxy decoders matching dest IP against a CDB list -->
    <if_sid>80700</if_sid> <!-- Placeholder parent rule, normally tied to generic firewall rule -->
    <!-- Requires a CDB list in practice. Simulating with regex for proxy logic -->
    <regex type="pcre2">(?i)(tor_exit_node_detected|dstip="known_tor_node")</regex>
    <description>Connection to known TOR exit node (Command and Control)</description>
    <mitre>
      <id>T1090.003</id>
    </mitre>
    <group>DE.CM-01, DE.AE-03</group>
  </rule>

  <!-- Helper Rule 100054: IPv4 network connection helper -->
  <rule id="100054" level="0">
    <decoded_as>json</decoded_as>
    <field name="win.system.providerName">Microsoft-Windows-Sysmon</field>
    <field name="win.system.eventID">^3$</field>
    <field name="win.eventdata.destinationIsIpv6">false</field>
    <description>Helper: Sysmon Network Connection IPv4</description>
  </rule>

  <!-- Rule 100046: Beaconing Behaviour -->
  <rule id="100046" level="9" frequency="20" timeframe="600">
    <!-- Detects frequent connections to the same external IP within a 10m window -->
    <if_matched_sid>100054</if_matched_sid>
    <same_source_ip />
    <description>Potential beaconing behaviour: high frequency connections to same host (Command and Control)</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>DE.AE-02, DE.CM-01</group>
  </rule>

  <!-- Rule 100047: Certutil Used to Download File -->
  <rule id="100047" level="10">
    <decoded_as>json</decoded_as>
    <field name="win.system.providerName">Microsoft-Windows-Sysmon</field>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)certutil\.exe.*(\-urlcache|\-split|\-f|http(s)?:\/\/)</field>
    <description>Certutil used to download remote payload (C2/Defense Evasion)</description>
    <mitre>
      <id>T1105</id>
    </mitre>
    <group>DE.AE-02, DE.CM-01</group>
  </rule>

  <!-- Rule 100048: Regsvr32/Rundll32 Executing Remote Script -->
  <rule id="100048" level="10">
    <decoded_as>json</decoded_as>
    <field name="win.system.providerName">Microsoft-Windows-Sysmon</field>
    <field name="win.system.eventID">^1$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(regsvr32\.exe|rundll32\.exe).*(http(s)?:\/\/|scrobj\.dll|\/i:)</field>
    <description>Regsvr32/Rundll32 remote script execution (Defense Evasion)</description>
    <mitre>
      <id>T1218.010</id>
    </mitre>
    <group>DE.AE-02, DE.CM-01</group>
  </rule>

</group>
